# IronKey minimal Linux kernel config
# Target: latest LTS kernel, stripped to USB recovery tool essentials

# ── Core / architecture ─────────────────────────────────────────────────────
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_PREEMPT=y
CONFIG_HZ_1000=y
CONFIG_NO_HZ=y
CONFIG_HIGH_RES_TIMERS=y

# ── ACPI / power ─────────────────────────────────────────────────────────────
CONFIG_ACPI=y
CONFIG_ACPI_BUTTON=y
CONFIG_POWER_SUPPLY=y
CONFIG_SUSPEND=y

# ── PCI ──────────────────────────────────────────────────────────────────────
CONFIG_PCI=y
CONFIG_PCI_MSI=y

# ── USB host controllers ──────────────────────────────────────────────────────
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_UHCI_HCD=y
CONFIG_USB_OHCI_HCD=y

# ── USB storage ───────────────────────────────────────────────────────────────
CONFIG_USB_STORAGE=y
CONFIG_USB_UAS=y

# ── Storage buses ─────────────────────────────────────────────────────────────
CONFIG_ATA=y
CONFIG_SATA_AHCI=y
CONFIG_ATA_PIIX=y
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PCI=y
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI_MULTI_LUN=y

# ── Filesystems ───────────────────────────────────────────────────────────────
CONFIG_EXT2_FS=y
CONFIG_EXT3_FS=y
CONFIG_EXT4_FS=y
CONFIG_VFAT_FS=y
CONFIG_EXFAT_FS=y
CONFIG_NTFS3_FS=y
CONFIG_BTRFS_FS=y
CONFIG_XFS_FS=y
CONFIG_HFS_FS=y
CONFIG_HFSPLUS_FS=y
CONFIG_ISO9660_FS=y
CONFIG_UDF_FS=y
CONFIG_FUSE_FS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_F2FS_FS=y

# ── Crypto (for LUKS) ────────────────────────────────────────────────────────
CONFIG_CRYPTO=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_XTS=y
CONFIG_DM_CRYPT=y
CONFIG_BLK_DEV_DM=y
CONFIG_DM_UEVENT=y

# ── DRM / KMS display ────────────────────────────────────────────────────────
CONFIG_DRM=y
CONFIG_DRM_I915=y
CONFIG_DRM_AMDGPU=y
CONFIG_DRM_VMWGFX=y
CONFIG_DRM_VBOXVIDEO=m
CONFIG_DRM_NOUVEAU=m
CONFIG_DRM_SIMPLEDRM=y
CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_DRM_FBDEV_EMULATION=y

# ── HID (keyboard/mouse) ─────────────────────────────────────────────────────
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y
CONFIG_INPUT=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_MOUSE_PS2=y

# ── Serial / TTY ──────────────────────────────────────────────────────────────
CONFIG_TTY=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_SERIAL_8250=y

# ── Memory / misc ─────────────────────────────────────────────────────────────
CONFIG_BOUNCE=y
CONFIG_ZSMALLOC=y
CONFIG_TRANSPARENT_HUGEPAGE=y

# ── Explicitly disabled (keep image small) ────────────────────────────────────
# CONFIG_WLAN is not set
# CONFIG_BT is not set
# CONFIG_SOUND is not set
# CONFIG_MEDIA_SUPPORT is not set
# CONFIG_USB_NET_DRIVERS is not set
# CONFIG_NFS_FS is not set
# CONFIG_CIFS is not set
